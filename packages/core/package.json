{
  "name": "@route-intelligence/core",
  "version": "2.0.0",
  "description": "Core routing intelligence engine for React applications",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@route-intelligence/shared": "*",
    "chokidar": "^4.0.3",
    "fast-glob": "^3.3.3",
    "graphology": "^0.26.0",
    "graphology-dag": "^0.4.1",
    "graphology-shortest-path": "^2.1.0",
    "graphology-traversal": "^0.3.1",
    "picomatch": "^4.0.2",
    "ts-morph": "^25.0.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@route-intelligence/tsconfig": "*",
    "@types/node": "^22.15.32",
    "@types/picomatch": "^4.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
