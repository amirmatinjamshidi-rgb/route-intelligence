{
  "name": "route-intelligence",
  "version": "1.0.0",
  "private": true,
  "description": "Routing intelligence platform for React applications",
  "type": "module",
  "workspaces": ["packages/*", "apps/*", "tooling/*"],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "node scripts/build-packages.mjs",
    "vercel-build": "next build",
    "dev": "node scripts/run-package.mjs @route-intelligence/cli dev",
    "docs:dev": "next dev",
    "docs:build": "next build",
    "docs:start": "next start",
    "typecheck": "node scripts/run-workspaces.mjs typecheck",
    "test": "node scripts/run-workspaces.mjs test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "analyze": "node packages/cli/bin/route-intelligence.mjs analyze",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "node scripts/build-packages.mjs && changeset publish",
    "postinstall": "node scripts/verify-workspaces.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.31.0",
    "@route-intelligence/cli": "*",
    "@route-intelligence/tsconfig": "*",
    "@tailwindcss/postcss": "^4.3.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "license": "MIT",
  "dependencies": {
    "clsx": "^2.1.1",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "overrides": {
    "postcss": "^8.5.15",
    "esbuild": "^0.25.12",
    "js-yaml": "^4.1.2"
  }
}
